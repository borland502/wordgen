#!/usr/bin/env bash

set -euo pipefail

watch_file go.mod
watch_file Taskfile.yml

PROJECT_ROOT="$(pwd)"
TOOLS_DIR="${PROJECT_ROOT}/.tools"
LOCAL_BIN="${TOOLS_DIR}/bin"
LOCAL_GO_ROOT="${TOOLS_DIR}/go"
DOWNLOAD_DIR="${TOOLS_DIR}/downloads"
GO_VERSION="$({
  awk '
    /^toolchain / && $2 != "default" { toolchain = $2 }
    /^go / && goversion == "" { goversion = $2 }
    END {
      version = (toolchain != "" ? toolchain : goversion)
      sub(/^go/, "", version)
      sub(/^v/, "", version)
      print version
    }
  ' go.mod
})"
TASK_VERSION="v3.45.5"
DOWNLOAD_TIMEOUT_SECONDS="${GSEA_DOWNLOAD_TIMEOUT_SECONDS:-30}"

PATH_add "$LOCAL_BIN"

normalize_version() {
  local version="$1"
  version="${version#go}"
  version="${version#v}"
  printf '%s' "$version"
}

current_go_version() {
  if ! command -v go >/dev/null 2>&1; then
    return 1
  fi

  if go env GOVERSION >/dev/null 2>&1; then
    normalize_version "$(go env GOVERSION)"
    return 0
  fi

  normalize_version "$(go version | awk '{print $3}')"
}

current_task_version() {
  if ! command -v task >/dev/null 2>&1; then
    return 1
  fi

  normalize_version "$(task --version | grep -Eo 'v?[0-9]+\.[0-9]+\.[0-9]+' | head -n1)"
}

go_install_root() {
  printf '%s' "${LOCAL_GO_ROOT}/${GO_VERSION}"
}

go_archive_name() {
  local go_os go_arch

  case "$(uname -s)" in
    Darwin) go_os="darwin" ;;
    Linux) go_os="linux" ;;
    *)
      echo "direnv: unsupported OS for automatic Go install: $(uname -s)" >&2
      return 1
      ;;
  esac

  case "$(uname -m)" in
    arm64|aarch64) go_arch="arm64" ;;
    x86_64|amd64) go_arch="amd64" ;;
    *)
      echo "direnv: unsupported architecture for automatic Go install: $(uname -m)" >&2
      return 1
      ;;
  esac

  printf 'go%s.%s-%s.tar.gz' "$GO_VERSION" "$go_os" "$go_arch"
}

go_download_url() {
  printf 'https://go.dev/dl/%s' "$(go_archive_name)"
}

json_python() {
  if command -v python3 >/dev/null 2>&1; then
    printf '%s' "python3"
    return 0
  fi
  if command -v python >/dev/null 2>&1; then
    printf '%s' "python"
    return 0
  fi

  echo "direnv: python3 or python is required to verify Go downloads" >&2
  return 1
}

archive_sha256() {
  local archive_path="$1"

  if command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$archive_path" | awk '{print $1}'
    return 0
  fi
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$archive_path" | awk '{print $1}'
    return 0
  fi

  echo "direnv: shasum or sha256sum is required to verify Go downloads" >&2
  return 1
}

go_expected_sha256() {
  local python_bin archive_name version timeout_seconds

  python_bin="$(json_python)" || return 1
  archive_name="$(go_archive_name)" || return 1
  version="go${GO_VERSION}"
  timeout_seconds="${DOWNLOAD_TIMEOUT_SECONDS}"

  "$python_bin" - "$version" "$archive_name" "$timeout_seconds" <<'PY'
import json
import sys
import urllib.request

version = sys.argv[1]
archive_name = sys.argv[2]
timeout_seconds = float(sys.argv[3])

try:
  with urllib.request.urlopen(
    "https://go.dev/dl/?mode=json&include=all",
    timeout=timeout_seconds,
  ) as response:
    releases = json.load(response)
except Exception as exc:
  raise SystemExit(
    f"unable to fetch Go release metadata within {timeout_seconds:g}s: {exc}"
  )

for release in releases:
    if release.get("version") != version:
        continue
    for item in release.get("files", []):
        if item.get("filename") == archive_name:
            sha256 = item.get("sha256", "")
            if not sha256:
                raise SystemExit("missing sha256 for " + archive_name)
            print(sha256)
            raise SystemExit(0)

raise SystemExit("checksum not found for " + archive_name)
PY
}

install_go() {
  local install_root archive_path download_url expected_sha256 actual_sha256

  install_root="$(go_install_root)"
  archive_path="${DOWNLOAD_DIR}/$(go_archive_name)"
  download_url="$(go_download_url)"

  mkdir -p "$DOWNLOAD_DIR"

  if [ ! -x "${install_root}/bin/go" ]; then
    echo "direnv: installing Go ${GO_VERSION} into ${install_root}"
    if ! curl --connect-timeout 10 --max-time "$DOWNLOAD_TIMEOUT_SECONDS" -fsSL "$download_url" -o "$archive_path"; then
      echo "direnv: failed to download ${download_url} within ${DOWNLOAD_TIMEOUT_SECONDS}s" >&2
      return 1
    fi
    expected_sha256="$(go_expected_sha256)"
    actual_sha256="$(archive_sha256 "$archive_path")"
    if [ "$actual_sha256" != "$expected_sha256" ]; then
      echo "direnv: checksum verification failed for ${archive_path}" >&2
      echo "direnv: expected ${expected_sha256}, got ${actual_sha256}" >&2
      rm -f "$archive_path"
      return 1
    fi
    rm -rf "$install_root"
    mkdir -p "$install_root"
    tar -C "$install_root" --strip-components=1 -xzf "$archive_path"
  fi

  PATH_add "${install_root}/bin"
}

ensure_go() {
  local current_version

  if current_version="$(current_go_version)"; then
    if [ "$current_version" = "$GO_VERSION" ]; then
      return 0
    fi
  fi

  install_go
}

ensure_task() {
  local desired_version current_version

  desired_version="$(normalize_version "$TASK_VERSION")"
  if current_version="$(current_task_version)"; then
    if [ "$current_version" = "$desired_version" ]; then
      return 0
    fi
  fi

  echo "direnv: installing Task ${TASK_VERSION} into ${LOCAL_BIN}"
  mkdir -p "$LOCAL_BIN"
  GOBIN="$LOCAL_BIN" GO111MODULE=on go install "github.com/go-task/task/v3/cmd/task@${TASK_VERSION}"
}

if [ -x "$(go_install_root)/bin/go" ]; then
  PATH_add "$(go_install_root)/bin"
fi

ensure_go
ensure_task

export GOTOOLCHAIN=local
export GOSEA_TASKFILE="${PROJECT_ROOT}/Taskfile.yml"
